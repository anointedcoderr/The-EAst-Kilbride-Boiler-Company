# Sample env file for EKBC. Copy to .env.local for local development
# or set the equivalent values in the Hostinger environment for
# production. Never commit real secrets.

# ---------------------------------------------------------------
# Quote form delivery mode. One of: mock | webhook | smtp
# Defaults to "mock" if unset.
# ---------------------------------------------------------------
EKBC_FORM_DELIVERY_MODE=smtp

# ---------------------------------------------------------------
# SMTP delivery (Hostinger). Required when
# EKBC_FORM_DELIVERY_MODE=smtp.
# ---------------------------------------------------------------
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@eastkilbrideboilercompany.co.uk
# Set SMTP_PASS in the Hostinger control panel, not in this file
SMTP_PASS=
SMTP_FROM=The East Kilbride Boiler Company <info@eastkilbrideboilercompany.co.uk>
QUOTE_FORM_TO=info@eastkilbrideboilercompany.co.uk

# ---------------------------------------------------------------
# Webhook delivery (alternative to SMTP). Required when
# EKBC_FORM_DELIVERY_MODE=webhook.
# ---------------------------------------------------------------
# EKBC_FORM_WEBHOOK_URL=https://hooks.zapier.com/...

# ---------------------------------------------------------------
# Admin Basic Auth - gates the /admin route. Set both values in
# Hostinger's env config. The /admin path returns 503 until these
# are present.
# ---------------------------------------------------------------
ADMIN_USER=
ADMIN_PASS=

# ---------------------------------------------------------------
# Supabase - backing store for quote_leads. SUPABASE_URL is the
# Hostinger-provided project URL. Prefer the service role key for
# server-only access; falls back to the anon key if the service key
# is absent (in that case configure RLS policies on quote_leads to
# allow inserts and selects from the server).
# ---------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
